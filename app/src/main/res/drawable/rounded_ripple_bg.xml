<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="?android:attr/colorControlHighlight">
    <!-- Define la máscara de la onda (ripple effect) -->
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <!-- La onda se aplica en esta área, con esquinas redondeadas -->
            <corners android:radius="100dp" />
            <!-- El color del fondo es un color primario para garantizar visibilidad -->
            <solid android:color="?android:attr/colorAccent" />
        </shape>
    </item>

    <!-- Define el contenido normal del botón (en este caso, transparente) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</ripple>