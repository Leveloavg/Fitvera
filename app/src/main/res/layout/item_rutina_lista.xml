<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="15dp"
    android:layout_marginBottom="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/card_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvNombreRutinaCard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre Rutina"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_color_normal" />

        <TextView
            android:id="@+id/tvInfoRutinaCard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Info"
            android:textColor="@color/text_color_muted" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/btnEditarRutina"
                style="?attr/borderlessButtonStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/btn_edit"
                android:textColor="@color/fitvera_blue"
                android:layout_marginEnd="4dp" /> <Button
            android:id="@+id/btnBorrarRutina"
            style="?attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/btn_delete"
            android:textColor="@color/streak_red"
            android:layout_marginHorizontal="4dp" /> <Button
            android:id="@+id/btnConfirmarRutina"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.5"
            android:text="@string/btn_confirm"
            android:backgroundTint="@color/fitvera_blue"
            android:textColor="@color/white"
            android:layout_marginStart="4dp" /> </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>