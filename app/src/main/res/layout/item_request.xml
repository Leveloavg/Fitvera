<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:background="@color/card_background">

    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/img_user_notification"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_default_profile"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/requestUnreadIndicator"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@android:color/holo_blue_light"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_user_name_notification"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="@string/notification_default_name"
        android:textColor="@color/text_color"
        android:textSize="16sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintEnd_toStartOf="@+id/requestUnreadIndicator"
        app:layout_constraintStart_toEndOf="@id/img_user_notification"
        app:layout_constraintTop_toTopOf="@id/img_user_notification" />

    <TextView
        android:id="@+id/tv_notification_type"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/notification_type_label"
        android:textColor="@color/text_color_muted"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/tv_user_name_notification"
        app:layout_constraintTop_toBottomOf="@id/tv_user_name_notification" />

    <LinearLayout
        android:id="@+id/layout_buttons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/tv_notification_type"
        app:layout_constraintStart_toStartOf="@id/tv_user_name_notification"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btn_reject"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#FF6B6B"
            android:text="@string/action_reject"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            app:cornerRadius="20dp" />

        <Button
            android:id="@+id/btn_accept"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:backgroundTint="#51CF66"
            android:text="@string/action_accept"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            app:cornerRadius="20dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>