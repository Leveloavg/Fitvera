<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp">


        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/animacion_lottie"
            android:layout_width="200dp"
            android:layout_height="200dp"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_rawRes="@raw/fitness"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/titulo_app"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auth_screen_app_title"
            android:textSize="40sp"
            android:textStyle="bold"
            android:textColor="#1d7dc8"
            android:letterSpacing="0.1"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="16dp" />

        <ImageView
            android:id="@+id/Logo"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:src="@drawable/logo"
            android:layout_marginBottom="40dp"
            android:contentDescription="@string/content_description_logo" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:boxBackgroundColor="@android:color/white"
            app:boxCornerRadiusBottomEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusTopStart="8dp"
            app:boxStrokeColor="#1d7dc8"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/campoemail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_username_auth"
                android:inputType="textEmailAddress"
                android:padding="16dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:boxBackgroundColor="@android:color/white"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="#1d7dc8"
            app:boxCornerRadiusBottomEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusTopStart="8dp"
            app:boxStrokeColor="#1d7dc8"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/campocontraseña"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_password_auth"
                android:inputType="textPassword"
                android:padding="16dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <CheckBox
            android:id="@+id/recordar_usuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recordar usuario"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/text_olvido"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/text_forgot_password"
            android:textColor="#1d7dc8"
            android:textStyle="bold"
            android:paddingVertical="8dp"
            android:layout_gravity="end"
            android:layout_marginBottom="24dp" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:visibility="gone"
            android:layout_gravity="center"
            android:indeterminateTint="#1d7dc8"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/botoniniciarsesion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/button_login"
            android:backgroundTint="#1d7dc8"
            android:textColor="@android:color/white"
            android:padding="16dp"
            android:textSize="16sp"
            app:cornerRadius="24dp"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/registrarse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/button_register"
            android:backgroundTint="#2ecc71"
            android:textColor="@android:color/white"
            android:padding="16dp"
            android:textSize="16sp"
            app:cornerRadius="24dp"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/login_google"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/button_login_google"
            android:backgroundTint="#4285F4"
            android:textColor="@android:color/white"
            app:icon="@drawable/google"
            app:iconTint="@android:color/white"
            android:padding="16dp"
            android:textSize="16sp"
            app:cornerRadius="24dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/iniciodesesion2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/text_error_message"
            android:textSize="14sp"
            android:textColor="#e74c3c"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/salir"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/button_exit_app"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="#aaaaaa"
            android:textColor="#aaaaaa"
            android:padding="14dp"
            app:cornerRadius="24dp"
            android:layout_marginTop="8dp"/>

    </LinearLayout>
</ScrollView>