<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/btnGuardarRutina"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/general_config"
                android:textStyle="bold"
                android:textColor="@color/text_color_normal"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/etNombreRutina"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_routine_name"
                android:textColor="@color/text_color_normal"
                android:textColorHint="@color/text_color_muted"
                android:background="@drawable/rounded_edittext"
                android:padding="12dp"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <EditText
                    android:id="@+id/etTiempo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/hint_time"
                    android:inputType="number"
                    android:textColor="@color/text_color_normal"
                    android:textColorHint="@color/text_color_muted"
                    android:background="@drawable/rounded_edittext"
                    android:padding="12dp"
                    android:layout_marginEnd="4dp"/>
                <Spinner
                    android:id="@+id/spinnerDificultad"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/rounded_edittext"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/exercises_added"
                    android:textColor="@color/text_color_normal"
                    android:textStyle="bold"
                    android:textSize="18sp"/>
                <ImageButton
                    android:id="@+id/btnAddEjercicio"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_input_add"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/fitvera_blue"/> </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvEjercicios"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnGuardarRutina"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        android:text="@string/btn_save_cloud"
        android:backgroundTint="@color/fitvera_blue"
        android:textColor="@color/white"/>
</RelativeLayout>