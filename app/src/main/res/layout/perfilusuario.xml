<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background">

    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/back_button_desc"
        android:src="@drawable/arrowback"
        app:tint="@color/text_color"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:elevation="4dp" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/perfil_title"
        android:textColor="@color/text_color"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginTop="12dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toBottomOf="@id/btn_back"
        app:layout_constraintStart_toStartOf="parent"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main_content_area"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@+id/tv_title"
        app:layout_constraintBottom_toTopOf="@+id/bottom_navigation_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:id="@+id/main_scroll_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="16dp">

            <LinearLayout
                android:id="@+id/content_container_scroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:visibility="gone"
                tools:visibility="visible">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardElevation="4dp"
                    android:layout_marginBottom="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/iv_profile_pic"
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:src="@drawable/profile_placeholder"
                            app:civ_border_width="3dp"
                            app:civ_border_color="@color/fitvera_blue"
                            android:layout_marginEnd="16dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:id="@+id/tv_user_name"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/user_name_placeholder"
                                    android:textColor="@color/fitvera_blue"
                                    android:textSize="22sp"
                                    android:textStyle="bold"/>

                                <ImageView
                                    android:id="@+id/iv_country_flag"
                                    android:layout_width="24dp"
                                    android:layout_height="18dp"
                                    android:layout_marginStart="8dp"
                                    android:scaleType="centerCrop"
                                    tools:src="@drawable/flag_placeholder" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tv_user_info"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/user_info_placeholder"
                                android:textColor="@color/text_color_muted"
                                android:textSize="14sp"/>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginTop="8dp">

                                <ImageView
                                    android:id="@+id/iv_streak_fire"
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/fuego"
                                    android:layout_marginEnd="4dp" />

                                <TextView
                                    android:id="@+id/tv_streak_days"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="@color/fitvera_blue"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tv_max_streak_days"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Máx: 0"
                                    android:textColor="@color/text_color_muted"
                                    android:textSize="14sp"
                                    android:layout_marginStart="8dp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="@string/latest_activities_title"
                    android:textColor="@color/text_color"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/card_recent_activities"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardElevation="4dp"
                    android:layout_marginBottom="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tv_last_activity_date"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/fitvera_blue"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            tools:text="15 de octubre de 2023"/>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1F575757" android:layout_marginVertical="8dp"/>

                        <TextView
                            android:id="@+id/tv_last_activity_distance"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/activity_distance_placeholder"
                            android:textColor="@color/text_color"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_last_activity_time"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/activity_time_placeholder"
                            android:textColor="@color/text_color_muted"
                            android:paddingTop="4dp"/>

                        <org.osmdroid.views.MapView
                            android:id="@+id/map_last_activity_preview"
                            android:layout_width="match_parent"
                            android:layout_height="150dp"
                            android:layout_marginTop="12dp"
                            android:visibility="gone"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/statistics_title"
                    android:textColor="@color/text_color"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="8dp" android:layout_marginBottom="16dp"
                            app:cardCornerRadius="16dp" app:cardBackgroundColor="@color/card_background" app:cardElevation="4dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_activity_label" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/fitvera_blue" />
                                <TextView android:id="@+id/other_user_tv_workouts_total_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="22sp" android:textStyle="bold" android:textColor="@color/text_color" tools:text="75" />
                                <TextView android:id="@+id/other_user_tv_workouts_month_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="11sp" android:textColor="@color/text_color_muted" tools:text="3 este mes" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:layout_marginBottom="16dp"
                            app:cardCornerRadius="16dp" app:cardBackgroundColor="@color/card_background" app:cardElevation="4dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_distance_label" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/fitvera_blue" />
                                <TextView android:id="@+id/other_user_tv_distance_total_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="22sp" android:textStyle="bold" android:textColor="@color/text_color" tools:text="450 km" />
                                <TextView android:id="@+id/other_user_tv_distance_month_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="11sp" android:textColor="@color/text_color_muted" tools:text="50 km este mes" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="8dp" android:layout_marginBottom="16dp"
                            app:cardCornerRadius="16dp" app:cardBackgroundColor="@color/card_background" app:cardElevation="4dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_time_label" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/fitvera_blue" />
                                <TextView android:id="@+id/other_user_tv_time_total_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="22sp" android:textStyle="bold" android:textColor="@color/text_color" tools:text="150 h" />
                                <TextView android:id="@+id/other_user_tv_time_month_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="11sp" android:textColor="@color/text_color_muted" tools:text="15 h este mes" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:layout_marginBottom="16dp"
                            app:cardCornerRadius="16dp" app:cardBackgroundColor="@color/card_background" app:cardElevation="4dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_elevation_label" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/fitvera_blue" />
                                <TextView android:id="@+id/other_user_tv_elevation_total_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="22sp" android:textStyle="bold" android:textColor="@color/text_color" tools:text="500 m" />
                                <TextView android:id="@+id/other_user_tv_elevation_month_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="11sp" android:textColor="@color/text_color_muted" tools:text="20 m este mes" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chart_title"
                    android:textColor="@color/text_color"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardElevation="4dp"
                    android:layout_marginBottom="24dp">
                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/activity_chart"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="8dp"/>
                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/achievements_title"
                    android:textColor="@color/text_color"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardElevation="4dp"
                    android:layout_marginBottom="24dp">

                    <androidx.gridlayout.widget.GridLayout
                        android:id="@+id/trophies_grid_layout_perfil"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:columnCount="4"
                        android:padding="8dp"
                        app:useDefaultMargins="true" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </ScrollView>

        <TextView
            android:id="@+id/tv_profile_privacy_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="32dp"
            android:text="@string/privacy_message"
            android:textColor="@color/text_color"
            android:textSize="18sp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/btn_follow_from_profile"
            app:layout_constraintVertical_chainStyle="packed"/>

        <Button
            android:id="@+id/btn_follow_from_profile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/follow_button_text"
            android:textColor="@color/white"
            android:backgroundTint="@color/fitvera_blue"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tv_profile_privacy_message"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <LinearLayout
            android:id="@+id/loading_indicator_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:background="#A0000000"
            android:visibility="gone">
            <ProgressBar android:layout_width="wrap_content" android:layout_height="wrap_content" android:indeterminateTint="@color/fitvera_blue" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="@string/loading_profile_text" android:textColor="@color/white" android:textSize="16sp" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/bottom_navigation_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/navigation_background"
        android:paddingVertical="8dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>