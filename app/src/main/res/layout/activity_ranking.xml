<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/screen_background"
        android:stateListAnimator="@null"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:layout_scrollFlags="scroll|enterAlways"
            android:background="@color/screen_background">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/btn_back"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_alignParentStart="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/back_button_description"
                    android:src="@drawable/arrowback"
                    app:tint="@color/text_color_normal" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="@string/ranking_general_title"
                    android:textColor="@color/text_color_normal"
                    android:textSize="20sp"
                    android:textStyle="bold" />

            </RelativeLayout>
        </androidx.appcompat.widget.Toolbar>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/metric_toggle_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <Button
                    android:id="@+id/btn_ritmo_promedio"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ranking_metric_pace"
                    android:textColor="@color/text_color_selector"
                    app:cornerRadius="16dp"
                    android:backgroundTint="@color/toggle_button_background_selector"
                    app:strokeColor="@color/toggle_button_stroke_selector" />

                <Button
                    android:id="@+id/btn_kilometros"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ranking_metric_distance"
                    android:textColor="@color/text_color_selector"
                    app:cornerRadius="16dp"
                    android:checked="true"
                    android:backgroundTint="@color/toggle_button_background_selector"
                    app:strokeColor="@color/toggle_button_stroke_selector" />

                <Button
                    android:id="@+id/btn_actividades"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ranking_metric_activities"
                    android:textColor="@color/text_color_selector"
                    app:cornerRadius="16dp"
                    android:backgroundTint="@color/toggle_button_background_selector"
                    app:strokeColor="@color/toggle_button_stroke_selector" />

                <Button
                    android:id="@+id/btn_territorios"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ranking_metric_territories"
                    android:textColor="@color/text_color_selector"
                    app:cornerRadius="16dp"
                    android:backgroundTint="@color/toggle_button_background_selector"
                    app:strokeColor="@color/toggle_button_stroke_selector" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

        </HorizontalScrollView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_time_filters"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/stroke_color"
            app:strokeWidth="1dp">

            <RadioGroup
                android:id="@+id/time_radio_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/card_background">

                <RadioButton
                    android:id="@+id/radio_semana"
                    style="@style/RankingRadioButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/time_scope_week"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/radio_mes"
                    style="@style/RankingRadioButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/time_scope_month" />

                <RadioButton
                    android:id="@+id/radio_year"
                    style="@style/RankingRadioButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/time_scope_year" />

                <RadioButton
                    android:id="@+id/radio_total"
                    style="@style/RankingRadioButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/time_scope_total" />
            </RadioGroup>
        </com.google.android.material.card.MaterialCardView>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/ranking_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        tools:listitem="@layout/item_ranking_user" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>