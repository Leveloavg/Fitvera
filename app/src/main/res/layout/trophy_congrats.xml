<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:background="@drawable/rounded_card_bg"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/congrats_header"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/gold_color" />

    <ImageView
        android:id="@+id/iv_congrats_trophy"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginVertical="16dp" />

    <TextView
        android:id="@+id/tv_congrats_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/trophy_title_placeholder"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btn_congrats_close"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/congrats_button" />
</LinearLayout>