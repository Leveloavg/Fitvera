<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/card_background"> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <EditText
            android:id="@+id/etNombreEx"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_toStartOf="@+id/btnDeleteEjercicio"
            android:background="@null"
            android:hint="@string/hint_exercise_name"
            android:textStyle="bold"
            android:textColor="@color/text_color_normal"
            android:textColorHint="@color/text_color_muted" />

        <ImageButton
            android:id="@+id/btnDeleteEjercicio"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="@color/streak_red" /> </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_color"
        android:layout_marginVertical="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/etSeries"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="@string/hint_series"
            android:inputType="number"
            android:gravity="center"
            android:textColor="@color/text_color_normal"
            android:textColorHint="@color/text_color_muted"
            android:background="@null"/>

        <EditText
            android:id="@+id/etReps"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="@string/hint_reps"
            android:inputType="number"
            android:gravity="center"
            android:textColor="@color/text_color_normal"
            android:textColorHint="@color/text_color_muted"
            android:background="@null"/>

        <EditText
            android:id="@+id/etPeso"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="@string/hint_weight"
            android:inputType="numberDecimal"
            android:gravity="center"
            android:textColor="@color/text_color_normal"
            android:textColorHint="@color/text_color_muted"
            android:background="@null"/>

    </LinearLayout>
</LinearLayout>
</androidx.cardview.widget.CardView>